make_plot <- function(df) {
df_sub <- df %>%
filter(source != "true distribution")
ggplot(df_sub, aes(x = time, color = source)) +
geom_hline(yintercept = 0, linetype = "dashed", alpha = 0.5) +
geom_ribbon(aes(ymin = lower_diff, ymax = upper_diff, fill = source),
alpha = 0.2, color = NA) +
geom_line(aes(y = mean_diff), linewidth = 1) +
geom_line(aes(y = median_diff, linetype = source), linewidth = 0.8) +
facet_grid(sample_size ~ model) +
labs(
x = NULL,
y = NULL,
color = "Source",
fill = "Source",
linetype = "Source"
) +
scale_color_manual(values = c(
"Naive estimator" = "gray40",
"MoM estimator" = "orange",
"ML estimator" = "blue"
)) +
scale_fill_manual(values = c(
"Naive estimator" = "gray40",
"MoM estimator" = "orange",
"ML estimator" = "blue"
)) +
scale_linetype_manual(values = c(
"Naive estimator" = "solid",
"MoM estimator" = "dashed",
"EM ML estimator" = "solid"
)) +
coord_cartesian(xlim = c(0, 5)) +
theme_minimal()
}
df_sub <- df_final %>%
filter(
source != "true distribution",
sample_size %in% c(100, 1000)
)
p6 <- make_plot(df_sub)
final_plot_p6 <- ggdraw(p6) +
draw_label("Years", x = 0.5, y = -0.5, vjust = -0.5) +
draw_label("Percentage deviation from true total population",
x = 0, y = 0.5, angle = 90, vjust = 1, size = 11)
final_plot_p6
ggsave("../figures/forcast_plot.pdf", final_plot_p6,
width = 14,
height = 10,
dpi = 300)
df_diff_i <- df_tv_deconv_i %>%
left_join(df_tv_true, by = "sample_size", suffix = c("", "_true")) %>%
mutate(
mean_diff = mean - mean_true,
median_diff = median - median_true,
upper_95_diff = upper_95 - upper_95_true,
method = "ML informed estimator"
)
df_diff_u <- df_tv_deconv_ml_u %>%
left_join(df_tv_true, by = "sample_size", suffix = c("", "_true")) %>%
mutate(
mean_diff = mean - mean_true,
median_diff = median - median_true,
upper_95_diff = upper_95 - upper_95_true,
method = "ML uninformed estimator"
)
df_diff_MoM <- deconvolved_mom_p_samples_i_fixed %>%
left_join(df_tv_true, by = "sample_size", suffix = c("", "_true")) %>%
mutate(
mean_diff = mean - mean_true,
median_diff = median - median_true,
upper_95_diff = upper_95 - upper_95_true,
method = "MoM estimator"
)
df_diff_c <- df_tv_c %>%
left_join(df_tv_true, by = "sample_size", suffix = c("", "_true")) %>%
mutate(
mean_diff = mean - mean_true,
median_diff = median - median_true,
upper_95_diff = upper_95 - upper_95_true,
method = "Naive estimator"
)
df_all <- rbind(df_diff_MoM,df_diff_u,df_diff_c)
df_all$method <- factor(df_all$method,
levels = c("Naive estimator", "MoM estimator", "ML estimator"))
# df_all <- rbind(
